# ===========================================
# BraidedByMae — Environment Variables (Dev)
# ===========================================
# Copy to .env.local and fill in values

# --- PostgreSQL (Docker Compose) ---
POSTGRES_USER=braidedbymae
POSTGRES_PASSWORD=braidedbymae_dev
POSTGRES_DB=braidedbymae

# --- Database URL (Prisma) ---
# Port 5433 when connecting from HOST (mapped in docker-compose)
# Port 5432 when connecting from INSIDE containers (service name "db")
DATABASE_URL=postgresql://braidedbymae:braidedbymae_dev@localhost:5433/braidedbymae

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# --- Resend (Email — not used in dev, Mailpit catches all) ---
RESEND_API_KEY=re_your-api-key

# --- Email (Dev — Mailpit SMTP) ---
# Use "mailpit" when running INSIDE Docker, "localhost" when running on host
SMTP_HOST=mailpit
SMTP_PORT=1025

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=mae@braidedbymae.de
ADMIN_PASSWORD_HASH=$2b$10$...
# Generate: node -e "require('bcryptjs').hash('your-password', 10).then(console.log)"
